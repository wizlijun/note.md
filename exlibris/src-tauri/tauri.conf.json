{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ExLibris",
  "version": "0.1.0",
  "identifier": "com.laobu.exlibris",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm --filter exlibris dev",
    "beforeBuildCommand": "pnpm --filter exlibris build"
  },
  "app": {
    "windows": [
      {
        "title": "ExLibris",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 500,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/wizlijun/MdEditor/main/exlibris/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDNzc1QjQ2MkFDM0JGNDEKUldSQnY4TXFSbHQzekhuY0c1b1VGQzc2aHN2OXBjRHFNVHh1d2xGVWIwL0ZSalBIYk9XVnJteVIK"
    }
  }
}

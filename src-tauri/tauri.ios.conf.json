{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "iOS": {
      "minimumSystemVersion": "18.0",
      "fileAssociations": [
        { "ext": ["md", "markdown", "mdown", "mkd"], "name": "Markdown", "role": "Editor" },
        { "ext": ["html", "htm"], "name": "HTML", "role": "Editor" },
        { "ext": ["txt", "log"], "name": "Plain Text", "role": "Editor" }
      ]
    }
  }
}

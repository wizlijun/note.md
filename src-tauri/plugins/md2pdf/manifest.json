{
  "id": "md2pdf",
  "name": "Export to PDF",
  "version": "0.1.0",
  "description": "Export the current Markdown or HTML tab to a typographically-clean A4 PDF",
  "binary": "bin",
  "menus": [
    {
      "location": "file",
      "label": "Export to PDF…",
      "shortcut": "Cmd+Shift+E",
      "command": "export",
      "enabled_when": "currentTab.kind == 'markdown' || currentTab.kind == 'html'",
      "prompt": {
        "kind": "save-dialog",
        "default_filename": "{stem}.pdf",
        "filters": [
          {
            "name": "PDF",
            "extensions": [
              "pdf"
            ]
          }
        ]
      }
    }
  ],
  "host_capabilities": [
    "renderer.html",
    "toast"
  ],
  "timeout_seconds": 60,
  "cli": [
    {
      "subcommand": "pdf",
      "aliases": [
        "--pdf"
      ],
      "command": "export",
      "summary": "Export Markdown or HTML file to PDF",
      "args": [
        {
          "name": "file",
          "type": "path",
          "required": true,
          "help": "Markdown or HTML file to export"
        }
      ],
      "flags": [
        {
          "long": "--output",
          "short": "-o",
          "type": "string",
          "help": "Output PDF path (default: <stem>.pdf in same directory)"
        }
      ],
      "requires_tab_context": true
    }
  ],
  "i18n": {
    "zh": {
      "name": "导出为 PDF",
      "description": "将当前 Markdown 或 HTML 标签页导出为排版精美的 A4 PDF",
      "menus": {
        "export": "导出为 PDF…"
      }
    },
    "ja": {
      "name": "PDF に書き出し",
      "description": "現在の Markdown または HTML タブを、組版の美しい A4 PDF に書き出します",
      "menus": {
        "export": "PDF に書き出し…"
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "note.md",
  "mainBinaryName": "notemd",
  "version": "5.24.0",
  "identifier": "net.notemd.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "note.md",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "plugins/**/*",
      "resources/themes/**/*"
    ],
    "category": "DeveloperTool",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": [
          "txt",
          "text",
          "log",
          "csv",
          "tsv",
          "env"
        ],
        "name": "Plain Text",
        "description": "Plain text file",
        "role": "Editor"
      },
      {
        "ext": [
          "srt",
          "vtt",
          "ass",
          "ssa"
        ],
        "name": "Subtitles",
        "description": "Subtitle file",
        "role": "Editor"
      },
      {
        "ext": [
          "rst",
          "org",
          "adoc",
          "asciidoc",
          "tex",
          "diff",
          "patch",
          "properties"
        ],
        "name": "Text Document",
        "description": "Plain-text document",
        "role": "Editor"
      },
      {
        "ext": [
          "json",
          "jsonc"
        ],
        "name": "JSON",
        "description": "JSON document",
        "role": "Editor"
      },
      {
        "ext": [
          "yaml",
          "yml"
        ],
        "name": "YAML",
        "description": "YAML document",
        "role": "Editor"
      },
      {
        "ext": [
          "toml",
          "ini",
          "conf"
        ],
        "name": "Config",
        "description": "Configuration file",
        "role": "Editor"
      },
      {
        "ext": [
          "xml"
        ],
        "name": "XML",
        "description": "XML document",
        "role": "Editor"
      },
      {
        "ext": [
          "sh",
          "bash",
          "zsh"
        ],
        "name": "Shell Script",
        "description": "Shell script",
        "role": "Editor"
      },
      {
        "ext": [
          "py"
        ],
        "name": "Python",
        "description": "Python source file",
        "role": "Editor"
      },
      {
        "ext": [
          "js",
          "mjs",
          "cjs",
          "jsx"
        ],
        "name": "JavaScript",
        "description": "JavaScript source file",
        "role": "Editor"
      },
      {
        "ext": [
          "ts",
          "tsx"
        ],
        "name": "TypeScript",
        "description": "TypeScript source file",
        "role": "Editor"
      },
      {
        "ext": [
          "rs"
        ],
        "name": "Rust",
        "description": "Rust source file",
        "role": "Editor"
      },
      {
        "ext": [
          "go"
        ],
        "name": "Go",
        "description": "Go source file",
        "role": "Editor"
      },
      {
        "ext": [
          "java"
        ],
        "name": "Java",
        "description": "Java source file",
        "role": "Editor"
      },
      {
        "ext": [
          "c",
          "cpp",
          "cc",
          "h",
          "hpp"
        ],
        "name": "C/C++",
        "description": "C / C++ source file",
        "role": "Editor"
      },
      {
        "ext": [
          "rb"
        ],
        "name": "Ruby",
        "description": "Ruby source file",
        "role": "Editor"
      },
      {
        "ext": [
          "swift"
        ],
        "name": "Swift",
        "description": "Swift source file",
        "role": "Editor"
      },
      {
        "ext": [
          "kt"
        ],
        "name": "Kotlin",
        "description": "Kotlin source file",
        "role": "Editor"
      },
      {
        "ext": [
          "php"
        ],
        "name": "PHP",
        "description": "PHP source file",
        "role": "Editor"
      },
      {
        "ext": [
          "cs"
        ],
        "name": "C#",
        "description": "C# source file",
        "role": "Editor"
      },
      {
        "ext": [
          "css",
          "scss"
        ],
        "name": "CSS",
        "description": "Stylesheet",
        "role": "Editor"
      },
      {
        "ext": [
          "sql"
        ],
        "name": "SQL",
        "description": "SQL script",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "endpoints": [
        "https://github.com/wizlijun/note.md/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDNzc1QjQ2MkFDM0JGNDEKUldSQnY4TXFSbHQzekhuY0c1b1VGQzc2aHN2OXBjRHFNVHh1d2xGVWIwL0ZSalBIYk9XVnJteVIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "mdeditor capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:menu:default",
    "core:path:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-open-url",
    "store:default"
  ]
}

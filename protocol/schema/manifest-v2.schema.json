{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ManifestV2",
  "type": "object",
  "required": [
    "activation",
    "capabilities",
    "engines",
    "id",
    "kind",
    "manifest_version",
    "name",
    "version"
  ],
  "properties": {
    "activation": {
      "$ref": "#/definitions/Activation"
    },
    "binary": {
      "default": {},
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contributes": {
      "default": {
        "cli": [],
        "context_menus": [],
        "custom_editors": [],
        "menus": [],
        "settings": null,
        "tray": [],
        "windows": []
      },
      "allOf": [
        {
          "$ref": "#/definitions/Contributes"
        }
      ]
    },
    "description": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "engines": {
      "$ref": "#/definitions/Engines"
    },
    "i18n": {
      "default": null
    },
    "id": {
      "type": "string"
    },
    "idle_shutdown_seconds": {
      "default": null,
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "kind": {
      "$ref": "#/definitions/PluginKind"
    },
    "manifest_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "name": {
      "type": "string"
    },
    "request_timeout_seconds": {
      "default": null,
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "ui": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Activation": {
      "type": "object",
      "required": [
        "events"
      ],
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "Contributes": {
      "type": "object",
      "properties": {
        "cli": {
          "default": [],
          "type": "array",
          "items": true
        },
        "context_menus": {
          "default": [],
          "type": "array",
          "items": true
        },
        "custom_editors": {
          "default": [],
          "type": "array",
          "items": true
        },
        "menus": {
          "default": [],
          "type": "array",
          "items": true
        },
        "settings": {
          "default": null
        },
        "tray": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/TrayContribution"
          }
        },
        "windows": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/WindowContribution"
          }
        }
      },
      "additionalProperties": false
    },
    "Engines": {
      "type": "object",
      "required": [
        "notemd"
      ],
      "properties": {
        "notemd": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "PluginKind": {
      "type": "string",
      "enum": [
        "native",
        "wasm"
      ]
    },
    "TrayContribution": {
      "description": "一个托盘启动项：宿主在菜单栏 tray 下拉里加一条,点击打开该插件的窗口。",
      "type": "object",
      "required": [
        "window"
      ],
      "properties": {
        "label": {
          "description": "托盘项文案；缺省用插件本地化名称（manifest `name` + `i18n.<locale>.name`）。",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "window": {
          "description": "要打开的窗口 id（须匹配某个 `contributes.windows[].id`）。",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "WindowContribution": {
      "type": "object",
      "required": [
        "entry",
        "height",
        "id",
        "width"
      ],
      "properties": {
        "entry": {
          "type": "string"
        },
        "height": {
          "type": "number",
          "format": "double"
        },
        "id": {
          "type": "string"
        },
        "min_height": {
          "default": null,
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "min_width": {
          "default": null,
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "open_command": {
          "description": "contributes.menus 中命中此 command 的菜单项 = 打开本窗口（不走 command.execute）。",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "singleton": {
          "default": true,
          "type": "boolean"
        },
        "title": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "width": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false
    }
  }
}

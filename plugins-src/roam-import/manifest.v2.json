{
  "manifest_version": 2,
  "id": "notemd.roam-import",
  "name": "Roam Research Import",
  "version": "1.0.2",
  "kind": "native",
  "engines": { "notemd": ">=6.716.7" },
  "description": "Import a Roam Research JSON export into the vault as .note.md outline pages and daily notes",
  "ui": "ui/",
  "activation": { "events": ["onCommand:open"] },
  "contributes": {
    "menus": [
      { "location": "file", "label": "Import from Roam Research…", "command": "open" }
    ],
    "windows": [
      {
        "id": "main",
        "entry": "index.html",
        "title": "Import from Roam Research",
        "width": 680.0,
        "height": 620.0,
        "min_width": 520.0,
        "min_height": 420.0,
        "open_command": "open"
      }
    ]
  },
  "capabilities": ["dialog", "vault.read", "vault.write", "fs.read:dialog", "clipboard.write", "toast"]
}

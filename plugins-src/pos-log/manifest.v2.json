{
  "manifest_version": 2,
  "id": "notemd.pos-log",
  "name": "Position Log",
  "version": "1.0.4",
  "kind": "native",
  "engines": { "notemd": ">=6.720.4" },
  "description": "Log your location (macOS system Location Services) to the vault: appends country-province-city + POI to pos/YYYY-MM-DD-pos.md whenever the address changes (every 30 min or on demand)",
  "binary": {
    "aarch64-apple-darwin": "bin/notemd-pos-log",
    "x86_64-apple-darwin": "bin/notemd-pos-log"
  },
  "activation": { "events": ["onStartupFinished", "onCommand:save-now"] },
  "contributes": {
    "menus": [
      { "location": "plugins", "label": "Save Location Now", "command": "save-now" }
    ]
  },
  "capabilities": ["location", "vault.read", "vault.write", "toast"],
  "request_timeout_seconds": 30
}

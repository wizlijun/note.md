{
  "manifest_version": 2,
  "id": "notemd.exlibris",
  "name": "ExLibris",
  "version": "1.0.1",
  "kind": "native",
  "engines": {
    "notemd": ">=6.716.7"
  },
  "description": "Import ebooks into your library: extract metadata via calibre, apply routing rules, and file each book into the sotvault. The whole import pipeline runs in this plugin's own process; the shared config (sotvault/rawvault/calibre) lives at the same path the standalone app used.",
  "binary": {
    "aarch64-apple-darwin": "bin/notemd-exlibris",
    "x86_64-apple-darwin": "bin/notemd-exlibris"
  },
  "ui": "ui/",
  "activation": {
    "events": [
      "onCommand:open"
    ]
  },
  "contributes": {
    "menus": [
      {
        "location": "window",
        "label": "ExLibris (v2)",
        "command": "open"
      }
    ],
    "windows": [
      {
        "id": "main",
        "entry": "index.html",
        "title": "ExLibris",
        "width": 1100,
        "height": 720,
        "min_width": 720,
        "min_height": 500,
        "open_command": "open"
      }
    ]
  },
  "capabilities": [
    "dialog",
    "toast"
  ],
  "i18n": {
    "zh": {
      "name": "ExLibris 藏书",
      "menus": {
        "open": "ExLibris 藏书 (v2)"
      }
    },
    "ja": {
      "name": "ExLibris 蔵書",
      "menus": {
        "open": "ExLibris 蔵書 (v2)"
      }
    },
    "de": {
      "name": "ExLibris",
      "menus": {
        "open": "ExLibris (v2)"
      }
    }
  }
}
